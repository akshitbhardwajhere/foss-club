generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(uuid())
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  email        String   @unique
}

model Event {
  id                 String                   @id @default(uuid())
  title              String
  description        String
  date               DateTime
  location           String
  imageUrl           String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  category           String
  documentUrl        String?
  isDateTentative    Boolean                  @default(false)
  registrationConfig EventRegistrationConfig?

  @@index([createdAt])
  @@index([date])
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  content   String
  author    String
  tags      String[]
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model TeamMember {
  id          String   @id @default(uuid())
  name        String
  role        String
  email       String   @unique
  githubUrl   String?
  linkedinUrl String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Int      @default(0)

  @@index([order])
}

model EventRegistrationConfig {
  id            String              @id @default(uuid())
  eventId       String              @unique
  validUntil    DateTime
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  registrations EventRegistration[]
  event         Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventRegistration {
  id             String                  @id @default(uuid())
  configId       String
  name           String
  email          String
  institute      String
  enrollmentNo   String?
  branch         String
  isIndividual   Boolean
  teamName       String?
  teamMembers    String[]
  areaOfInterest String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  config         EventRegistrationConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, email])
}
