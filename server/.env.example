# Database URL for Prisma (PostgreSQL connection string)
DATABASE_URL="postgresql://user:password@localhost:5432/foss_club?schema=public"

# Server Port
PORT=5000

# Node Environment (development or production)
NODE_ENV=development

# JWT Secret for authenticating routes (e.g. admin auth)
JWT_SECRET="your-jwt-secret-key-here"

# Client URLs allowed for CORS
CLIENT_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3001"

# Cloudinary credentials for media/document uploads
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Mailjet credentials for sending automated emails
MAILJET_API_KEY="your-mailjet-api-key"
MAILJET_API_SECRET="your-mailjet-api-secret"
MAILJET_FROM_EMAIL="your-registered-mailjet-email@example.com"

# Google Sheets credentials for synchronization workflows
GOOGLE_SHEET_ID="your-google-sheet-id"
GOOGLE_CLIENT_EMAIL="your-google-service-account-email@example.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
